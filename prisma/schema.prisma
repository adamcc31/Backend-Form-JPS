generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
}

enum RegistrationStatus {
  DRAFT
  PENDING
  REVIEW_IN_PROGRESS
  REVISION_REQUIRED
  APPROVED
  PROCESSED
}

enum DocumentType {
  KTP
  PASSPORT
  ZAIRYU_CARD
  OTHER
}

model Organization {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique @default(uuid()) // Slug untuk URL form publik, e.g. "lpk-sakura"
  branding_config Json          @default("{}") // JSONB: logo, warna, dsb.
  is_active       Boolean       @default(true)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  users           User[]
  dynamic_forms   DynamicForm[]
  registrations   Registration[]

  @@map("organizations")
}

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  password        String
  name            String
  role            Role
  organization_id String?
  organization    Organization? @relation(fields: [organization_id], references: [id])
  is_active       Boolean      @default(true)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  assigned_registrations Registration[] @relation("AssignedAgent")

  @@map("users")
}

model DynamicForm {
  id              String         @id @default(uuid())
  organization_id String
  organization    Organization   @relation(fields: [organization_id], references: [id])
  title           String         @default("Untitled Form") // Judul form
  schema_config   Json           // JSONB: { version, fields: [...] }
  header_config   Json           @default("{}") // JSONB: banner, logo, headline, theme
  document_config Json           @default("{}") // JSONB: konfigurasi dokumen wajib upload
  is_active       Boolean        @default(true)
  published_at    DateTime?      // Waktu form dipublikasikan
  expires_at      DateTime?      // Waktu form kadaluarsa (opsional)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  registrations   Registration[]

  @@map("dynamic_forms")
}

model Registration {
  id                String             @id @default(uuid())
  tracking_code     String             @unique // Kode unik 12-char untuk cek status publik
  organization_id   String
  organization      Organization       @relation(fields: [organization_id], references: [id])
  dynamic_form_id   String
  dynamic_form      DynamicForm        @relation(fields: [dynamic_form_id], references: [id])
  passport_number   String
  full_name         String
  dynamic_data      Json               @default("{}") // JSONB: responses dari dynamic form
  documents         Json               @default("{}") // JSONB: metadata file dokumen
  status            RegistrationStatus @default(DRAFT)
  assigned_agent_id String?
  assigned_agent    User?              @relation("AssignedAgent", fields: [assigned_agent_id], references: [id])
  notes             String?            // Catatan internal (tidak visible ke siswa)
  submitted_at      DateTime?          // Waktu submit oleh siswa
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  document_files    DocumentFile[]

  @@map("registrations")
}

model DocumentFile {
  id                    String       @id @default(uuid())
  registration_id       String
  registration          Registration @relation(fields: [registration_id], references: [id])
  document_type         DocumentType
  storage_key           String       // Path file di storage (terenkripsi)
  original_filename     String
  file_size_bytes       Int
  mime_type             String       // image/jpeg atau image/png
  enhancement_metadata  Json         @default("{}") // Log proses enhancement
  ocr_data              Json         @default("{}") // Hasil OCR jika diaktifkan
  uploaded_at           DateTime     @default(now())
  expires_at            DateTime?    // Auto-delete setelah retention period

  @@map("document_files")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  table_name  String
  record_id   String
  action      String   // INSERT, UPDATE, DELETE
  old_data    Json?
  new_data    Json?
  changed_by  String?  // User ID or system
  changed_at  DateTime @default(now())
  ip_address  String?  // IP address client

  @@map("audit_logs")
}
